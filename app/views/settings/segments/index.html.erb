<% content_for(:title, "Segments — Propeller") %>

<nav class="fixed top-0 left-0 right-0 z-50 bg-gray-950/80 backdrop-blur-lg border-b border-white/5">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="text-2xl font-bold text-white tracking-tight">
      <img src="/logo.svg" alt="Propeller" style="height: 30px; display: inline-block;">
    </a>
    <div class="flex items-center gap-4">
      <a href="/dashboard" class="text-sm text-gray-400 hover:text-white focus:outline-none focus:ring-2 focus:ring-indigo-400 rounded">Dashboard</a>
      <a href="<%= settings_api_keys_path %>" class="text-sm text-gray-400 hover:text-white focus:outline-none focus:ring-2 focus:ring-indigo-400 rounded">API keys</a>
      <span class="text-sm text-gray-400"><%= current_user.email %></span>
      <%= button_to "Log out", logout_path, method: :delete, class: "px-4 py-2 text-sm font-medium text-gray-300 hover:text-white border border-gray-700 hover:border-gray-600 rounded-full transition-all duration-200" %>
    </div>
  </div>
</nav>

<main class="min-h-screen bg-gray-950 pt-24 px-6">
  <div class="max-w-4xl mx-auto py-12">
    <header class="mb-8 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3">
      <div>
        <h1 class="text-3xl font-bold text-white mb-2">Segments</h1>
        <p class="text-gray-400">Define rule sets that filter contacts on demand. Use them in campaigns and sequences.</p>
      </div>
      <a href="<%= new_settings_segment_path %>" class="inline-flex items-center justify-center px-5 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white font-medium focus:outline-none focus:ring-2 focus:ring-indigo-400">
        New segment
      </a>
    </header>

    <% if flash[:notice] %>
      <div role="status" aria-live="polite" class="mb-6 rounded-2xl border border-emerald-700 bg-emerald-900/30 text-emerald-100 px-4 py-3">
        <%= flash[:notice] %>
      </div>
    <% end %>
    <% if flash[:alert] %>
      <div role="alert" aria-live="assertive" class="mb-6 rounded-2xl border border-red-700 bg-red-900/30 text-red-100 px-4 py-3">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <% if @segments.empty? %>
      <p class="text-gray-500">No segments yet. Create one to start filtering contacts by rules.</p>
    <% else %>
      <ul class="space-y-3" role="list">
        <% @segments.each do |segment| %>
          <li class="rounded-2xl border border-gray-800 bg-gray-900/40 px-5 py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
            <div>
              <p class="text-white font-medium"><%= segment.name %></p>
              <p class="text-sm text-gray-400">
                <%= pluralize(segment.rule_list.length, "rule") %>
                · matching <%= segment.matching_count %>
                <% if segment.contact_list %>
                  · within list <%= segment.contact_list.name %>
                <% end %>
              </p>
              <p class="text-xs text-gray-500 mt-1">Created <%= segment.created_at.to_date.iso8601 %></p>
            </div>
            <div class="flex gap-2">
              <a href="<%= edit_settings_segment_path(segment) %>" class="px-4 py-2 text-sm font-medium text-indigo-300 hover:text-indigo-100 border border-indigo-800 hover:border-indigo-600 rounded-full focus:outline-none focus:ring-2 focus:ring-indigo-500">Edit</a>
              <%= button_to "Delete", settings_segment_path(segment), method: :delete, data: { turbo_confirm: "Delete #{segment.name}? This cannot be undone." }, class: "px-4 py-2 text-sm font-medium text-red-300 hover:text-red-100 border border-red-800 hover:border-red-600 rounded-full focus:outline-none focus:ring-2 focus:ring-red-500" %>
            </div>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>
</main>
