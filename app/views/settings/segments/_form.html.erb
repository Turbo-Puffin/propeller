<%= form_with url: form_url, method: form_method, local: true, scope: nil, class: "space-y-6" do %>
  <div>
    <label for="segment_name" class="block text-sm font-medium text-gray-300 mb-1">Name</label>
    <input id="segment_name" type="text" name="name" required value="<%= @segment.name %>" class="w-full rounded-lg bg-gray-950 border border-gray-700 px-4 py-2 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500">
  </div>

  <div>
    <label for="segment_list" class="block text-sm font-medium text-gray-300 mb-1">Scope to list (optional)</label>
    <select id="segment_list" name="contact_list_id" class="w-full rounded-lg bg-gray-950 border border-gray-700 px-4 py-2 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500">
      <option value="">All contacts</option>
      <% @contact_lists.each do |list| %>
        <option value="<%= list.id %>" <%= "selected" if list.id == @segment.contact_list_id %>><%= list.name %></option>
      <% end %>
    </select>
  </div>

  <div>
    <label for="segment_rules" class="block text-sm font-medium text-gray-300 mb-1">Rules (JSON)</label>
    <p id="rules-help" class="text-xs text-gray-500 mb-2">Shape: <code class="text-indigo-300">{ "match": "all" | "any", "rules": [{ "property": "...", "op": "...", "value": "..." }] }</code></p>
    <textarea id="segment_rules" name="rules" rows="12" aria-describedby="rules-help" class="w-full rounded-lg bg-gray-950 border border-gray-700 px-4 py-2 text-white font-mono text-sm placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500"><%= JSON.pretty_generate(@segment.rules || { "match" => "all", "rules" => [] }) %></textarea>
  </div>

  <div class="flex items-center gap-3">
    <button type="submit" class="px-5 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white font-medium focus:outline-none focus:ring-2 focus:ring-indigo-400">
      <%= submit_label %>
    </button>
    <a href="<%= settings_segments_path %>" class="text-gray-400 hover:text-white focus:outline-none focus:ring-2 focus:ring-indigo-400 rounded px-2 py-1">Cancel</a>
  </div>
<% end %>
