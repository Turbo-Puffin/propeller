<% content_for(:title, "New segment — Propeller") %>

<nav class="fixed top-0 left-0 right-0 z-50 bg-gray-950/80 backdrop-blur-lg border-b border-white/5">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="text-2xl font-bold text-white tracking-tight">
      <img src="/logo.svg" alt="Propeller" style="height: 30px; display: inline-block;">
    </a>
    <div class="flex items-center gap-4">
      <a href="<%= settings_segments_path %>" class="text-sm text-gray-400 hover:text-white focus:outline-none focus:ring-2 focus:ring-indigo-400 rounded">Segments</a>
      <span class="text-sm text-gray-400"><%= current_user.email %></span>
      <%= button_to "Log out", logout_path, method: :delete, class: "px-4 py-2 text-sm font-medium text-gray-300 hover:text-white border border-gray-700 hover:border-gray-600 rounded-full transition-all duration-200" %>
    </div>
  </div>
</nav>

<main class="min-h-screen bg-gray-950 pt-24 px-6">
  <div class="max-w-3xl mx-auto py-12">
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-white mb-2">New segment</h1>
      <p class="text-gray-400">Define rules to filter contacts. JSON editor for v1; visual builder is coming.</p>
    </header>

    <% if flash[:alert] %>
      <div role="alert" aria-live="assertive" class="mb-6 rounded-2xl border border-red-700 bg-red-900/30 text-red-100 px-4 py-3">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <%= render "form",
              form_url: settings_segments_path,
              form_method: :post,
              submit_label: "Create segment" %>
  </div>
</main>
