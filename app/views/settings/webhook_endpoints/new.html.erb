<% content_for(:title, "New webhook — Propeller") %>

<%= render "nav" %>

<div class="min-h-screen bg-gray-950 pt-24 px-6 relative overflow-hidden">
  <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-indigo-600/10 rounded-full blur-3xl"></div>

  <div class="relative z-10 max-w-2xl mx-auto py-12">
    <h1 class="text-3xl font-bold text-white mb-2">Add webhook endpoint</h1>
    <p class="text-gray-400 mb-8">Choose which events Propeller should POST to your URL.</p>

    <div class="bg-gray-900/40 border border-gray-800 rounded-2xl p-8">
      <%= render "form", endpoint: @endpoint, form_url: settings_webhook_endpoints_path, form_method: :post, submit_label: "Create endpoint" %>
    </div>
  </div>
</div>
