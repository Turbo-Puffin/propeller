<% content_for(:title, "Edit webhook — Propeller") %>

<%= render "nav" %>

<div class="min-h-screen bg-gray-950 pt-24 px-6 relative overflow-hidden">
  <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-indigo-600/10 rounded-full blur-3xl"></div>

  <div class="relative z-10 max-w-2xl mx-auto py-12">
    <h1 class="text-3xl font-bold text-white mb-2">Edit webhook endpoint</h1>
    <p class="text-gray-400 mb-8 font-mono text-sm break-all"><%= @endpoint.url %></p>

    <div class="bg-gray-900/40 border border-gray-800 rounded-2xl p-8">
      <%= render "form", endpoint: @endpoint, form_url: settings_webhook_endpoint_path(@endpoint), form_method: :patch, submit_label: "Save changes" %>
    </div>
  </div>
</div>
