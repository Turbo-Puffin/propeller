<% content_for(:title, "New template — Propeller") %>

<%= render "nav" %>

<div class="min-h-screen bg-gray-950 pt-24 px-6">
  <div class="max-w-3xl mx-auto py-12">
    <h1 class="text-3xl font-bold text-white mb-2">New email template</h1>
    <p class="text-gray-400 mb-8">Prepare a reusable template that campaigns and sequences can render.</p>

    <div class="bg-gray-900/40 border border-gray-800 rounded-2xl p-6 sm:p-8">
      <%= render "form",
            form_url: settings_email_templates_path,
            submit_label: "Create template",
            cancel_url: settings_email_templates_path %>
    </div>
  </div>
</div>
