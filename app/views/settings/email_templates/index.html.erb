<% content_for(:title, "Email templates — Propeller") %>

<%= render "nav" %>

<div class="min-h-screen bg-gray-950 pt-24 px-6 relative overflow-hidden">
  <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-indigo-600/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-violet-600/10 rounded-full blur-3xl"></div>

  <div class="relative z-10 max-w-5xl mx-auto py-12">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-3xl font-bold text-white mb-2">Email templates</h1>
        <p class="text-gray-400">Reusable HTML + Liquid templates that campaigns can reference.</p>
      </div>
      <%= link_to "New template", new_settings_email_template_path,
            class: "px-4 py-2 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-500 focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-400 rounded-full transition-all" %>
    </div>

    <div class="flex gap-2 mb-6" role="tablist" aria-label="Filter templates by status">
      <% [ [ "All", nil ], [ "Active", "active" ], [ "Archived", "archived" ] ].each do |label, value| %>
        <% selected = @status_filter == value %>
        <%= link_to label, settings_email_templates_path(status: value),
              role: "tab",
              "aria-selected": selected.to_s,
              class: [ "px-3 py-1 text-sm rounded-full border", selected ? "bg-indigo-600 text-white border-indigo-500" : "text-gray-300 border-gray-700 hover:border-gray-500" ].join(" ") %>
      <% end %>
    </div>

    <% if flash[:notice].present? %>
      <div class="mb-6 p-4 rounded-lg bg-emerald-900/30 border border-emerald-700/50 text-emerald-200" role="status">
        <%= flash[:notice] %>
      </div>
    <% end %>
    <% if flash[:alert].present? %>
      <div class="mb-6 p-4 rounded-lg bg-rose-900/30 border border-rose-700/50 text-rose-200" role="alert">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <% if @templates.empty? %>
      <div class="bg-gray-900/40 border border-gray-800 rounded-2xl p-10 text-center">
        <p class="text-gray-200 text-lg mb-2">No templates yet.</p>
        <p class="text-gray-400 text-sm">Create a template to reuse across campaigns and sequences.</p>
      </div>
    <% else %>
      <div class="bg-gray-900/40 border border-gray-800 rounded-2xl overflow-hidden">
        <table class="w-full text-left">
          <thead class="bg-gray-900/60 text-xs uppercase tracking-wider text-gray-300">
            <tr>
              <th class="px-6 py-3" scope="col">Name</th>
              <th class="px-6 py-3" scope="col">Slug</th>
              <th class="px-6 py-3" scope="col">Subject</th>
              <th class="px-6 py-3" scope="col">Status</th>
              <th class="px-6 py-3" scope="col">Updated</th>
              <th class="px-6 py-3" scope="col"><span class="sr-only">Actions</span></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <% @templates.each do |template| %>
              <tr class="hover:bg-gray-900/60">
                <td class="px-6 py-4 text-sm text-white font-medium"><%= template.name %></td>
                <td class="px-6 py-4 text-sm text-gray-300 font-mono"><%= template.slug %></td>
                <td class="px-6 py-4 text-sm text-gray-300 max-w-xs truncate"><%= template.subject_template.presence || "(none)" %></td>
                <td class="px-6 py-4 text-sm">
                  <% if template.active? %>
                    <span class="px-2 py-0.5 text-xs rounded-full bg-emerald-900/40 border border-emerald-700/40 text-emerald-200">Active</span>
                  <% else %>
                    <span class="px-2 py-0.5 text-xs rounded-full bg-gray-800 border border-gray-700 text-gray-200">Archived</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 text-sm text-gray-400">
                  <%= time_ago_in_words(template.updated_at) %> ago
                </td>
                <td class="px-6 py-4 text-right text-sm">
                  <%= link_to "Open", settings_email_template_path(template), class: "text-indigo-300 hover:text-indigo-200 focus:outline-none focus-visible:underline" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</div>
