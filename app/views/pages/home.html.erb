<style>
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 20px rgba(124, 58, 237, 0.3); }
    50% { box-shadow: 0 0 40px rgba(124, 58, 237, 0.6); }
  }
  .animate-fade-in-up { animation: fade-in-up 0.8s ease-out both; }
  .animate-fade-in { animation: fade-in 0.6s ease-out both; }
  .delay-100 { animation-delay: 0.1s; }
  .delay-200 { animation-delay: 0.2s; }
  .delay-300 { animation-delay: 0.3s; }
  .delay-400 { animation-delay: 0.4s; }
  .delay-500 { animation-delay: 0.5s; }
  .delay-600 { animation-delay: 0.6s; }
</style>

<!-- Navigation -->
<nav class="fixed top-0 left-0 right-0 z-50 bg-gray-950/80 backdrop-blur-lg border-b border-white/5">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="text-2xl font-bold text-white tracking-tight">
      🚀 <span class="bg-gradient-to-r from-indigo-400 to-violet-400 bg-clip-text text-transparent">Propeller</span>
    </a>
    <a href="#waitlist" class="hidden sm:inline-flex items-center px-5 py-2.5 text-sm font-semibold text-white bg-gradient-to-r from-indigo-600 to-violet-600 rounded-full hover:from-indigo-500 hover:to-violet-500 transition-all duration-200 shadow-lg shadow-violet-500/25">
      Get Early Access
    </a>
  </div>
</nav>

<!-- Hero Section -->
<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-gray-950">
  <!-- Background gradient orbs -->
  <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-indigo-600/20 rounded-full blur-3xl"></div>
  <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-violet-600/20 rounded-full blur-3xl"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-indigo-500/10 rounded-full blur-3xl"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center pt-24 pb-20">
    <div class="animate-fade-in-up">
      <span class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-indigo-300 bg-indigo-500/10 border border-indigo-500/20 rounded-full mb-8">
        <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
        Now in early access
      </span>
    </div>

    <h1 class="animate-fade-in-up delay-100 text-5xl sm:text-6xl md:text-7xl font-extrabold text-white leading-tight tracking-tight mb-6">
      Email Marketing<br>
      <span class="bg-gradient-to-r from-indigo-400 via-violet-400 to-purple-400 bg-clip-text text-transparent">on Autopilot</span>
    </h1>

    <p class="animate-fade-in-up delay-200 text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed">
      Meet the AI that writes, tests, and optimizes your email campaigns autonomously.
      Stop guessing. Start growing. Let Propeller handle the rest.
    </p>

    <div class="animate-fade-in-up delay-300 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="#waitlist" class="group inline-flex items-center px-8 py-4 text-lg font-semibold text-white bg-gradient-to-r from-indigo-600 to-violet-600 rounded-full hover:from-indigo-500 hover:to-violet-500 transition-all duration-300 shadow-2xl shadow-violet-500/30 hover:shadow-violet-500/50 hover:-translate-y-0.5">
        Get Early Access
        <svg class="ml-2 w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
      <a href="#how-it-works" class="inline-flex items-center px-8 py-4 text-lg font-semibold text-gray-300 hover:text-white transition-colors duration-200">
        See how it works
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
  </div>
</section>

<!-- Features Section -->
<section class="relative bg-gray-950 py-24 sm:py-32">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16 sm:mb-20">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-4">
        Your AI email team,<br class="hidden sm:inline"> <span class="text-indigo-400">working 24/7</span>
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Propeller doesn't just send emails — it thinks, adapts, and improves on its own.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <!-- Feature 1 -->
      <div class="group relative p-8 rounded-2xl bg-gray-900/50 border border-gray-800 hover:border-indigo-500/50 transition-all duration-300 hover:-translate-y-1">
        <div class="w-14 h-14 mb-6 rounded-xl bg-gradient-to-br from-indigo-600 to-violet-600 flex items-center justify-center shadow-lg shadow-indigo-500/25">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/></svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-3">Agentic Campaigns</h3>
        <p class="text-gray-400 leading-relaxed">
          AI writes compelling subject lines, body copy, and iterates based on real performance data. Every send is smarter than the last.
        </p>
      </div>

      <!-- Feature 2 -->
      <div class="group relative p-8 rounded-2xl bg-gray-900/50 border border-gray-800 hover:border-violet-500/50 transition-all duration-300 hover:-translate-y-1">
        <div class="w-14 h-14 mb-6 rounded-xl bg-gradient-to-br from-violet-600 to-purple-600 flex items-center justify-center shadow-lg shadow-violet-500/25">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-3">Autonomous A/B Testing</h3>
        <p class="text-gray-400 leading-relaxed">
          AI generates multiple variants, runs statistically sound tests, and picks winners automatically. No manual intervention needed.
        </p>
      </div>

      <!-- Feature 3 -->
      <div class="group relative p-8 rounded-2xl bg-gray-900/50 border border-gray-800 hover:border-purple-500/50 transition-all duration-300 hover:-translate-y-1">
        <div class="w-14 h-14 mb-6 rounded-xl bg-gradient-to-br from-purple-600 to-pink-600 flex items-center justify-center shadow-lg shadow-purple-500/25">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 010 3.75H5.625a1.875 1.875 0 010-3.75z"/></svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-3">Smart Sequences</h3>
        <p class="text-gray-400 leading-relaxed">
          Automated email sequences that adapt in real time based on subscriber behavior. The right message, at the right moment.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- How It Works Section -->
<section id="how-it-works" class="relative bg-gray-900 py-24 sm:py-32">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16 sm:mb-20">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-4">
        Three steps to <span class="text-violet-400">liftoff</span>
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Get up and running in minutes, not months.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 md:gap-12">
      <!-- Step 1 -->
      <div class="relative text-center">
        <div class="w-20 h-20 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-indigo-600/20 to-violet-600/20 border border-indigo-500/30 flex items-center justify-center">
          <span class="text-3xl font-bold bg-gradient-to-r from-indigo-400 to-violet-400 bg-clip-text text-transparent">1</span>
        </div>
        <h3 class="text-xl font-bold text-white mb-3">Connect</h3>
        <p class="text-gray-400 leading-relaxed">
          Link your email provider and import your subscriber list. We integrate with all major platforms.
        </p>
        <!-- Arrow (hidden on mobile) -->
        <div class="hidden md:block absolute top-10 -right-6 lg:-right-8">
          <svg class="w-12 h-12 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="relative text-center">
        <div class="w-20 h-20 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-violet-600/20 to-purple-600/20 border border-violet-500/30 flex items-center justify-center">
          <span class="text-3xl font-bold bg-gradient-to-r from-violet-400 to-purple-400 bg-clip-text text-transparent">2</span>
        </div>
        <h3 class="text-xl font-bold text-white mb-3">Configure</h3>
        <p class="text-gray-400 leading-relaxed">
          Tell Propeller about your brand voice, goals, and audience. Set guardrails and let AI do the rest.
        </p>
        <!-- Arrow (hidden on mobile) -->
        <div class="hidden md:block absolute top-10 -right-6 lg:-right-8">
          <svg class="w-12 h-12 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="text-center">
        <div class="w-20 h-20 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-purple-600/20 to-pink-600/20 border border-purple-500/30 flex items-center justify-center">
          <span class="text-3xl font-bold bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent">3</span>
        </div>
        <h3 class="text-xl font-bold text-white mb-3">Let AI Take Over</h3>
        <p class="text-gray-400 leading-relaxed">
          Propeller autonomously creates, tests, and optimizes campaigns. You review results and watch your metrics climb.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Waitlist / Email Capture Section -->
<section id="waitlist" class="relative bg-gray-950 py-24 sm:py-32 overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-gradient-to-b from-indigo-600/10 to-transparent rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 max-w-2xl mx-auto px-6 text-center">
    <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-4">
      Ready for <span class="bg-gradient-to-r from-indigo-400 to-violet-400 bg-clip-text text-transparent">takeoff</span>?
    </h2>
    <p class="text-gray-400 text-lg mb-10 max-w-lg mx-auto">
      Join the waitlist for early access. Be among the first to put your email marketing on autopilot.
    </p>

    <% if flash[:notice] %>
      <div class="mb-8 p-4 rounded-xl bg-green-500/10 border border-green-500/30 text-green-300 text-sm font-medium">
        ✓ <%= flash[:notice] %>
      </div>
    <% end %>

    <% if flash[:alert] %>
      <div class="mb-8 p-4 rounded-xl bg-red-500/10 border border-red-500/30 text-red-300 text-sm font-medium">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <%= form_with url: waitlist_path, method: :post, local: true, class: "flex flex-col sm:flex-row gap-3 max-w-lg mx-auto" do |f| %>
      <input
        type="email"
        name="email"
        required
        placeholder="you@company.com"
        class="flex-1 px-5 py-4 rounded-full bg-gray-900 border border-gray-700 text-white placeholder-gray-500 focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 transition-all duration-200 text-base"
      >
      <button
        type="submit"
        class="px-8 py-4 text-base font-semibold text-white bg-gradient-to-r from-indigo-600 to-violet-600 rounded-full hover:from-indigo-500 hover:to-violet-500 transition-all duration-300 shadow-xl shadow-violet-500/25 hover:shadow-violet-500/40 hover:-translate-y-0.5 whitespace-nowrap cursor-pointer"
      >
        Join the Waitlist
      </button>
    <% end %>

    <p class="mt-5 text-sm text-gray-500">
      No spam, ever. We'll only email you when we're ready to launch.
    </p>
  </div>
</section>

<!-- Footer -->
<footer class="bg-gray-950 border-t border-gray-800/50 py-12">
  <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4">
    <a href="/" class="text-xl font-bold text-white tracking-tight">
      🚀 <span class="bg-gradient-to-r from-indigo-400 to-violet-400 bg-clip-text text-transparent">Propeller</span>
    </a>
    <p class="text-gray-500 text-sm">
      Built by <a href="https://rudder.so" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors duration-200 underline underline-offset-4 decoration-gray-600 hover:decoration-violet-400">Rudder</a>
    </p>
  </div>
</footer>
