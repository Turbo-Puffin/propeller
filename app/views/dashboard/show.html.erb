<% content_for(:title, "Dashboard — Propeller") %>

<!-- Navigation -->
<nav class="fixed top-0 left-0 right-0 z-50 bg-gray-950/80 backdrop-blur-lg border-b border-white/5">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="text-2xl font-bold text-white tracking-tight">
      🚀 <span class="bg-gradient-to-r from-indigo-400 to-violet-400 bg-clip-text text-transparent">Propeller</span>
    </a>
    <div class="flex items-center gap-4">
      <span class="text-sm text-gray-400"><%= current_user.email %></span>
      <%= button_to "Log out", logout_path, method: :delete, class: "px-4 py-2 text-sm font-medium text-gray-300 hover:text-white border border-gray-700 hover:border-gray-600 rounded-full transition-all duration-200" %>
    </div>
  </div>
</nav>

<div class="min-h-screen bg-gray-950 pt-24 px-6 relative overflow-hidden">
  <!-- Background orbs -->
  <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-indigo-600/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-violet-600/10 rounded-full blur-3xl"></div>

  <div class="relative z-10 max-w-4xl mx-auto py-12">
    <!-- Welcome card -->
    <div class="bg-gray-900/60 border border-gray-800 rounded-2xl p-8 sm:p-10 shadow-2xl mb-8">
      <div class="flex items-start gap-4">
        <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-indigo-600 to-violet-600 flex items-center justify-center shadow-lg shadow-indigo-500/25 shrink-0">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
        </div>
        <div>
          <h1 class="text-2xl sm:text-3xl font-bold text-white mb-2">
            Welcome, <%= current_user.name %>!
          </h1>
          <p class="text-gray-400 text-lg">
            You're logged in to <span class="text-indigo-400 font-semibold"><%= current_user.account.name %></span>
          </p>
        </div>
      </div>
    </div>

    <!-- Info cards -->
    <div class="grid sm:grid-cols-2 gap-6">
      <div class="bg-gray-900/40 border border-gray-800 rounded-2xl p-6">
        <h3 class="text-sm font-medium text-gray-400 uppercase tracking-wider mb-3">Account</h3>
        <p class="text-xl font-semibold text-white"><%= current_user.account.name %></p>
        <p class="text-sm text-gray-500 mt-1">Plan: <span class="text-indigo-400 capitalize"><%= current_user.account.plan %></span></p>
      </div>
      <div class="bg-gray-900/40 border border-gray-800 rounded-2xl p-6">
        <h3 class="text-sm font-medium text-gray-400 uppercase tracking-wider mb-3">Profile</h3>
        <p class="text-xl font-semibold text-white"><%= current_user.email %></p>
        <p class="text-sm text-gray-500 mt-1">Role: <span class="text-violet-400 capitalize"><%= current_user.role %></span></p>
      </div>
    </div>
  </div>
</div>
