<% content_for(:title, "Audit Log - Propeller") %>

<nav class="fixed top-0 left-0 right-0 z-50 bg-gray-950/80 backdrop-blur-lg border-b border-white/5">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/dashboard" class="text-2xl font-bold text-white tracking-tight">
      <img src="/logo.svg" alt="Propeller" style="height: 30px; display: inline-block;">
    </a>
    <div class="flex items-center gap-4">
      <span class="text-sm text-gray-400"><%= current_user.email %></span>
      <%= button_to "Log out", logout_path, method: :delete, class: "px-4 py-2 text-sm font-medium text-gray-300 hover:text-white border border-gray-700 hover:border-gray-600 rounded-full transition-all duration-200" %>
    </div>
  </div>
</nav>

<div class="min-h-screen bg-gray-950 pt-24 px-6 relative overflow-hidden">
  <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-indigo-600/10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative z-10 max-w-6xl mx-auto py-8">
    <header class="flex flex-wrap items-end justify-between gap-4 mb-8">
      <div>
        <h1 class="text-3xl font-bold text-white">Audit log</h1>
        <p class="text-gray-400 mt-1">Every change made by people, agents, and the system.</p>
      </div>

      <%= link_to dashboard_audit_index_path(format: :csv, **@filters),
                  class: "inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-400 rounded-full transition-colors",
                  aria: { label: "Export current audit results as CSV" } do %>
        <svg class="w-4 h-4" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M4 6h16M4 18h16"/></svg>
        Export CSV
      <% end %>
    </header>

    <%= form_with url: dashboard_audit_index_path, method: :get, local: true, class: "bg-gray-900/60 border border-gray-800 rounded-2xl p-5 mb-6 grid sm:grid-cols-2 lg:grid-cols-5 gap-4" do %>
      <div>
        <%= label_tag :actor_type, "Actor", class: "block text-xs font-medium uppercase tracking-wider text-gray-400 mb-2" %>
        <%= select_tag :actor_type,
                       options_for_select([ [ "All", "" ], [ "Human", "User" ], [ "Agent / API key", "ApiKey" ], [ "System", "System" ] ], @filters[:actor_type]),
                       class: "w-full bg-gray-950 border border-gray-800 rounded-lg px-3 py-2 text-sm text-white focus:border-indigo-500 focus:outline-none" %>
      </div>
      <div>
        <%= label_tag :event_action, "Action", class: "block text-xs font-medium uppercase tracking-wider text-gray-400 mb-2" %>
        <%= text_field_tag :event_action, @filters[:event_action], placeholder: "e.g. contact.created",
                           class: "w-full bg-gray-950 border border-gray-800 rounded-lg px-3 py-2 text-sm text-white focus:border-indigo-500 focus:outline-none" %>
      </div>
      <div>
        <%= label_tag :target_type, "Target type", class: "block text-xs font-medium uppercase tracking-wider text-gray-400 mb-2" %>
        <%= text_field_tag :target_type, @filters[:target_type], placeholder: "e.g. Contact",
                           class: "w-full bg-gray-950 border border-gray-800 rounded-lg px-3 py-2 text-sm text-white focus:border-indigo-500 focus:outline-none" %>
      </div>
      <div>
        <%= label_tag :from, "From", class: "block text-xs font-medium uppercase tracking-wider text-gray-400 mb-2" %>
        <%= date_field_tag :from, @filters[:from],
                           class: "w-full bg-gray-950 border border-gray-800 rounded-lg px-3 py-2 text-sm text-white focus:border-indigo-500 focus:outline-none" %>
      </div>
      <div>
        <%= label_tag :to, "To", class: "block text-xs font-medium uppercase tracking-wider text-gray-400 mb-2" %>
        <%= date_field_tag :to, @filters[:to],
                           class: "w-full bg-gray-950 border border-gray-800 rounded-lg px-3 py-2 text-sm text-white focus:border-indigo-500 focus:outline-none" %>
      </div>

      <div class="sm:col-span-2 lg:col-span-5 flex items-center gap-3">
        <%= submit_tag "Apply filters",
                       class: "px-4 py-2 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-400 rounded-full cursor-pointer" %>
        <%= link_to "Clear", dashboard_audit_index_path,
                    class: "px-4 py-2 text-sm font-medium text-gray-300 hover:text-white border border-gray-700 hover:border-gray-600 rounded-full" %>
      </div>
    <% end %>

    <div class="bg-gray-900/40 border border-gray-800 rounded-2xl overflow-hidden">
      <% if @events.any? %>
        <table class="w-full text-left text-sm">
          <caption class="sr-only">Audit events for <%= current_account.name %></caption>
          <thead class="bg-gray-900/80 text-gray-400 uppercase text-xs tracking-wider">
            <tr>
              <th scope="col" class="px-4 py-3">When</th>
              <th scope="col" class="px-4 py-3">Actor</th>
              <th scope="col" class="px-4 py-3">Action</th>
              <th scope="col" class="px-4 py-3">Target</th>
              <th scope="col" class="px-4 py-3">Summary</th>
              <th scope="col" class="px-4 py-3"><span class="sr-only">Details</span></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800/80 text-gray-200">
            <% @events.each do |event| %>
              <tr class="hover:bg-gray-900/60">
                <td class="px-4 py-3 whitespace-nowrap text-gray-400">
                  <time datetime="<%= event.created_at.iso8601 %>"><%= event.created_at.strftime("%Y-%m-%d %H:%M:%S") %></time>
                </td>
                <td class="px-4 py-3 whitespace-nowrap">
                  <span class="inline-flex items-center gap-2">
                    <span class="inline-block px-2 py-0.5 text-xs rounded-full <%= actor_badge_class(event.actor_type) %>"><%= event.actor_type %></span>
                    <span class="text-gray-300"><%= event.actor_label %></span>
                  </span>
                </td>
                <td class="px-4 py-3 font-mono text-xs text-indigo-300"><%= event.action %></td>
                <td class="px-4 py-3 text-gray-300">
                  <% if event.target_type.present? %>
                    <%= event.target_type %>
                    <span class="text-gray-500 font-mono text-xs"><%= event.target_id.to_s.first(8) %></span>
                  <% else %>
                    <span class="text-gray-600">None</span>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-gray-400 max-w-md truncate">
                  <%= event.reason || (event.metadata["diff"].is_a?(Hash) && event.metadata["diff"].keys.join(", ").presence) || "" %>
                </td>
                <td class="px-4 py-3 text-right">
                  <%= link_to "View", dashboard_audit_path(event),
                              class: "text-indigo-400 hover:text-indigo-300 underline-offset-2 hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-400 rounded" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <div class="p-10 text-center text-gray-400">
          <p class="text-lg">No audit events yet for these filters.</p>
        </div>
      <% end %>
    </div>

    <% if @pages.to_i > 1 %>
      <nav class="flex items-center justify-between mt-6 text-sm text-gray-400" aria-label="Audit log pagination">
        <span>Page <%= @page %> of <%= @pages %> &middot; <%= @total %> events</span>
        <div class="flex gap-2">
          <% if @page > 1 %>
            <%= link_to "Previous", dashboard_audit_index_path(page: @page - 1, **@filters),
                        class: "px-3 py-1 border border-gray-700 hover:border-gray-500 rounded-full" %>
          <% end %>
          <% if @page < @pages %>
            <%= link_to "Next", dashboard_audit_index_path(page: @page + 1, **@filters),
                        class: "px-3 py-1 border border-gray-700 hover:border-gray-500 rounded-full" %>
          <% end %>
        </div>
      </nav>
    <% end %>
  </div>
</div>
