<% content_for(:title, "Audit event - Propeller") %>

<nav class="fixed top-0 left-0 right-0 z-50 bg-gray-950/80 backdrop-blur-lg border-b border-white/5">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/dashboard" class="text-2xl font-bold text-white tracking-tight">
      <img src="/logo.svg" alt="Propeller" style="height: 30px; display: inline-block;">
    </a>
    <div class="flex items-center gap-4">
      <span class="text-sm text-gray-400"><%= current_user.email %></span>
      <%= button_to "Log out", logout_path, method: :delete, class: "px-4 py-2 text-sm font-medium text-gray-300 hover:text-white border border-gray-700 hover:border-gray-600 rounded-full transition-all duration-200" %>
    </div>
  </div>
</nav>

<div class="min-h-screen bg-gray-950 pt-24 px-6">
  <div class="max-w-4xl mx-auto py-8">
    <%= link_to "← Back to audit log", dashboard_audit_index_path,
                class: "text-sm text-indigo-400 hover:text-indigo-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-400 rounded" %>

    <h1 class="text-3xl font-bold text-white mt-4 mb-1"><%= @event.action %></h1>
    <p class="text-gray-400 mb-6">
      <time datetime="<%= @event.created_at.iso8601 %>"><%= @event.created_at.strftime("%Y-%m-%d %H:%M:%S %Z") %></time>
    </p>

    <dl class="bg-gray-900/60 border border-gray-800 rounded-2xl p-6 grid sm:grid-cols-2 gap-x-8 gap-y-5 mb-6">
      <div>
        <dt class="text-xs uppercase tracking-wider text-gray-400">Actor</dt>
        <dd class="mt-1 text-white">
          <span class="inline-block px-2 py-0.5 mr-2 text-xs rounded-full <%= actor_badge_class(@event.actor_type) %>"><%= @event.actor_type %></span>
          <%= @event.actor_label %>
        </dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wider text-gray-400">Target</dt>
        <dd class="mt-1 text-white">
          <% if @event.target_type.present? %>
            <%= @event.target_type %> <span class="font-mono text-gray-400 text-sm"><%= @event.target_id %></span>
          <% else %>
            <span class="text-gray-500">None</span>
          <% end %>
        </dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wider text-gray-400">Request IP</dt>
        <dd class="mt-1 text-white font-mono text-sm"><%= @event.request_ip.presence || "-" %></dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wider text-gray-400">User agent</dt>
        <dd class="mt-1 text-gray-300 text-sm break-all"><%= @event.user_agent.presence || "-" %></dd>
      </div>
    </dl>

    <% if @event.reason %>
      <section class="bg-gray-900/60 border border-gray-800 rounded-2xl p-6 mb-6">
        <h2 class="text-sm uppercase tracking-wider text-gray-400 mb-2">Reason</h2>
        <p class="text-white"><%= @event.reason %></p>
      </section>
    <% end %>

    <% diff = @event.metadata["diff"] %>
    <% if diff.present? %>
      <section class="bg-gray-900/60 border border-gray-800 rounded-2xl p-6 mb-6">
        <h2 class="text-sm uppercase tracking-wider text-gray-400 mb-3">Changes</h2>
        <pre class="bg-gray-950 border border-gray-800 rounded-lg p-4 text-xs text-gray-200 overflow-x-auto"><code><%= JSON.pretty_generate(diff) %></code></pre>
      </section>
    <% end %>

    <section class="bg-gray-900/60 border border-gray-800 rounded-2xl p-6">
      <h2 class="text-sm uppercase tracking-wider text-gray-400 mb-3">Full metadata</h2>
      <pre class="bg-gray-950 border border-gray-800 rounded-lg p-4 text-xs text-gray-200 overflow-x-auto"><code><%= JSON.pretty_generate(@event.metadata) %></code></pre>
    </section>
  </div>
</div>
